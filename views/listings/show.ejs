<% layout("layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container mt-4">

  <!-- Title -->
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">
      <h2 class="mb-3"><%= listing.title %></h2>
    </div>
  </div>

  <!-- Listing -->
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">
      <div class="card listing-card show-card shadow-sm">

        <img
          src="<%= listing.image.url %>"
          class="card-img-top show-img"
          alt="listing image"
        >

        <div class="card-body">
          <p><strong>Category:</strong> <%= listing.category %></p>
          <p><strong>Owned by:</strong> <%= listing.owner.username %></p>
          <p><%= listing.description %></p>
          <p>₹<%= listing.price.toLocaleString("en-IN") %> per night</p>
          <p><%= listing.location %>, <%= listing.country %></p>
        </div>

      </div>
    </div>
  </div>

  <!-- Edit/Delete -->
  <% if (currUser && currUser._id.equals(listing.owner._id)) { %>

    <div class="row justify-content-center mt-3">
      <div class="col-12 col-lg-8">
        <div class="d-flex gap-2">

          <a
            href="/listings/<%= listing._id %>/edit"
            class="btn btn-dark"
          >
            Edit
          </a>

          <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
          >
            <button class="btn btn-dark">
              Delete
            </button>
          </form>

        </div>
      </div>
    </div>

  <% } %>

  <!-- Review Form -->
  <% if (currUser) { %>

    <div class="row justify-content-center mt-4">
      <div class="col-12 col-lg-8">

        <hr>

        <h4>Leave a review</h4>

        <form
          action="/listings/<%= listing._id %>/reviews"
          method="POST"
          class="needs-validation"
          novalidate
        >

          <div class="mb-3">
            <label class="form-label">Rating</label>

            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked>

              <input type="radio" id="first-rate1" name="review[rating]" value="1">
              <label for="first-rate1">1</label>

              <input type="radio" id="first-rate2" name="review[rating]" value="2">
              <label for="first-rate2">2</label>

              <input type="radio" id="first-rate3" name="review[rating]" value="3">
              <label for="first-rate3">3</label>

              <input type="radio" id="first-rate4" name="review[rating]" value="4">
              <label for="first-rate4">4</label>

              <input type="radio" id="first-rate5" name="review[rating]" value="5">
              <label for="first-rate5">5</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label class="form-label">Comment</label>

            <textarea
              class="form-control"
              name="review[comment]"
              rows="5"
              required
            ></textarea>

            <div class="invalid-feedback">
              Please add some comment.
            </div>

          </div>

          <button class="btn btn-outline-dark">
            Submit
          </button>

        </form>

        <hr>

      </div>
    </div>

  <% } %>

  <!-- Reviews -->
  <% if (listing.reviews.length > 0) { %>

    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">

        <h4 class="mb-3">All Reviews</h4>

        <div class="row g-3">

          <% for (let review of listing.reviews) { %>

            <div class="col-12 col-md-6">

              <div class="card h-100 shadow-sm">

                <div class="card-body">

                  <h5 class="card-title">
                    @<%= review.author.username %>
                  </h5>

                  <p
                    class="starability-result"
                    data-rating="<%= review.rating %>"
                  >
                    Rated: <%= review.rating %> stars
                  </p>

                  <p><%= review.comment %></p>

                </div>

                <div class="card-footer bg-white border-0">

                  <form
                    method="POST"
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                  >
                    <button class="btn btn-sm btn-dark">
                      Delete
                    </button>
                  </form>

                </div>

              </div>

            </div>

          <% } %>

        </div>

      </div>
    </div>

  <% } %>

  <!-- Map -->
  <div class="row justify-content-center mt-5">
    <div class="col-12 col-lg-8">

      <h3>Where you'll be</h3>

      <div id="map"></div>

    </div>
  </div>

</div>

<script src="/js/map.js"></script>